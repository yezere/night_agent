{
  "name": "night_agent",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "start": "bun run apps/cli/src/main.ts",
    "audit": "bun run apps/cli/src/main.ts audit",
    "batch": "bun run apps/cli/src/main.ts batch",
    "inspect-result": "bun run scripts/inspect-audit-result.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun run apps/cli/src/main.ts audit --target test/fixtures/vulnerable-app --name vuln-app"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
